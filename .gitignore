# Python
__pycache__/
*.pyc
.ipynb_checkpoints/
venv/
.venv/

# OS
.DS_Store

# NOTE: data/ is intentionally NOT ignored here.
# The app reads data/calories.csv at runtime, so it must be committed
# to the repository. If you fork this project, double-check that no
# broader .gitignore rule (e.g. "*.csv" or "data/") gets added later —
# that is the single most common cause of the
# "FileNotFoundError: data/calories.csv" error on Streamlit Cloud.
